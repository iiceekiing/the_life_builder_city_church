# Backend Environment Variables
# Copy this to .env and update with your values

# Security
SECRET_KEY=your-super-secret-jwt-key-here-make-it-long-and-random-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database - Render will provide this automatically
DATABASE_URL=postgresql://username:password@host:port/database_name

# CORS - Update with your Vercel frontend URL
CORS_ORIGINS=https://the-life-builder-city-church.vercel.app,https://localhost:3000

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB

# Email (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true
